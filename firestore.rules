rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each authenticated user can only read and write their own document tree.
    // Structure: users/{uid}  +  subcollections cycles/, symptom_logs/, mood_logs/
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
